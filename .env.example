# Copy to .env and fill in. All optional — the agent runs with zero config.

# ---- Telegram push (optional; CLI works without it) ----
# Create a bot via @BotFather, then get your chat id via @userinfobot.
MH_TG_TOKEN=
MH_TG_CHAT_ID=

# ---- tuning (all optional; defaults shown) ----
# MH_POLL_SECONDS=30        # how often to poll GeckoTerminal
# MH_MIN_LIQ=4000           # reject pools with less pooled liquidity ($)
# MH_MIN_BUYERS=3           # reject pools with fewer unique 1h buyers
# MH_MAX_AGE_MIN=240        # ignore pools older than this (min) — we hunt early
# MH_LATE_PUMP=500          # 1h % gain above which entry is flagged "late"
# MH_TIER_WATCH=42          # score cutoffs for tiers
# MH_TIER_ALERT=60
# MH_TIER_HOT=78
# MH_COOLDOWN_MIN=30        # re-alert cooldown for a still-hot token
# MH_GOPLUS=1               # 1=try GoPlus token-security enrichment, 0=off
# RH_RPC_URL=https://rpc.mainnet.chain.robinhood.com
